# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://aic_user:aic_password@localhost:5432/aic_db

# ── JWT Auth ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=African Intelligence Cloud
APP_VERSION=0.1.0
ALLOWED_ORIGINS=http://localhost:3000

# ── Dataset Storage (Sprint 2) ────────────────────────────────────────────────
STORAGE_BACKEND=local
UPLOAD_DIR=storage/uploads
MAX_UPLOAD_SIZE_MB=50

# ── World Bank API ────────────────────────────────────────────────────────────
WORLDBANK_BASE_URL=https://api.worldbank.org/v2

# ── Google Cloud ──────────────────────────────────────────────────────────────
# GCP project and region
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Set STORAGE_BACKEND=gcs to use Cloud Storage instead of local filesystem
# GCS_BUCKET_NAME must match the bucket created by Terraform
GCS_BUCKET_NAME=aic-datasets-your-gcp-project-id

# BigQuery dataset for the analytics pipeline
BIGQUERY_DATASET=aic_analytics

# Secret Manager — set true in production to load DATABASE_URL and SECRET_KEY from GCP
# Requires Application Default Credentials with roles/secretmanager.secretAccessor
USE_SECRET_MANAGER=false

# Path to service account JSON key (local dev only; prefer Workload Identity in production)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
